{
  "version": 4,
  "configurations": [
    {
      "name": "Windows CUDA",
      "intelliSenseMode": "windows-msvc-x64",
      "cStandard": "c17",
      "cppStandard": "c++17",
      "defines": [
        "__CUDACC__"
      ],
      "includePath": [
        "${workspaceFolder}/**",
        "${env:CUDA_PATH}/include",
        "C:/Program Files/NVIDIA GPU Computing Toolkit/CUDA/v13.2/include",
        "C:/Program Files (x86)/Windows Kits/10/Include/**"
      ],
      "browse": {
        "path": [
          "${workspaceFolder}",
          "${env:CUDA_PATH}/include",
          "C:/Program Files/NVIDIA GPU Computing Toolkit/CUDA/v13.2/include"
        ],
        "limitSymbolsToIncludedHeaders": true
      }
    }
  ]
}
